# Copy this file to `.env` and fill in real values.
# Never commit the real `.env` — only `.env.example`.

DATABASE_URL="postgresql://user:password@localhost:5432/credit_recon"

# Generate with: openssl rand -hex 32
JWT_SECRET="replace-me-with-a-32-byte-hex-string"

JWT_EXPIRES_IN="1d"

# SMTP for password reset emails. Leave blank to log to console (dev).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Credit Recon <noreply@example.com>"

FRONTEND_URL="http://localhost:3001"

# When NODE_ENV=production:
#   - Auth cookie is set with Secure + SameSite=strict (requires HTTPS)
#   - CORS uses FRONTEND_URL instead of localhost
#   - app.set('trust proxy', 1) so req.ip reflects the Nginx-forwarded client
NODE_ENV="development"

# Anthropic API key for AI invoice extraction (Claude Haiku 4.5).
# Get one at https://console.anthropic.com/ → Settings → API Keys.
# Falls back to Tesseract when blank.
ANTHROPIC_API_KEY=""
